@model IReadOnlyList<WebThuMuaPheLieu.Models.Product>
@{
    var products = Model?.ToList() ?? new List<WebThuMuaPheLieu.Models.Product>();
}

@functions {
    string GetCategoryIcon(string? categoryName)
    {
        if (string.IsNullOrWhiteSpace(categoryName)) return "box-seam";

        return categoryName.ToLower() switch
        {
            var c when c.Contains("sắt") || c.Contains("thép") || c.Contains("kim loại") => "building",
            var c when c.Contains("đồng") || c.Contains("nhôm") || c.Contains("inox") => "gem",
            var c when c.Contains("giấy") || c.Contains("carton") => "box-seam",
            var c when c.Contains("máy") || c.Contains("điện") || c.Contains("cáp") => "cpu",
            var c when c.Contains("xưởng") || c.Contains("công nghiệp") => "gear-wide-connected",
            var c when c.Contains("dân dụng") || c.Contains("gia đình") => "house-door-fill",
            var c when c.Contains("nhựa") => "recycle",
            _ => "box-seam"
        };
    }

    string NormalizeImagePath(string? imagePath)
    {
        if (string.IsNullOrWhiteSpace(imagePath))
        {
            return "/assets/images/products/satdac1.jpg";
        }

        var normalized = imagePath.Replace("\\", "/").Trim();

        if (normalized.StartsWith("~/"))
        {
            return $"/{normalized[2..]}";
        }

        if (normalized.StartsWith("http://") || normalized.StartsWith("https://") || normalized.StartsWith("/"))
        {
            return normalized;
        }

        return $"/{normalized.TrimStart('/')}";
    }

    string[] BuildImageSequence(WebThuMuaPheLieu.Models.Product product)
    {
        var imageSequence = (product.ProductImages ?? new List<WebThuMuaPheLieu.Models.ProductImage>())
            .OrderBy(image => image.OrderIndex ?? int.MaxValue)
            .Select(image => NormalizeImagePath(image.ImageUrl))
            .Where(path => !string.IsNullOrWhiteSpace(path))
            .Distinct()
            .ToList();

        var primaryImage = NormalizeImagePath(product.PrimaryImage);

        if (!imageSequence.Any())
        {
            imageSequence.Add(primaryImage);
        }
        else if (!imageSequence.Any(path => string.Equals(path, primaryImage, StringComparison.OrdinalIgnoreCase)))
        {
            imageSequence.Insert(0, primaryImage);
        }

        return imageSequence.ToArray();
    }

}

@if (products.Any())
{
    <div class="related-products-swiper swiper detail-related-products-swiper" data-detail-autoplay="true">
        <div class="swiper-wrapper">
            @foreach (var product in products)
            {
                var imageSequence = BuildImageSequence(product);

                <div class="swiper-slide">
                    <a asp-controller="Home" asp-action="Detail" asp-route-slug="@product.Slug" asp-route-id="@product.Id"
                           class="card-item h-100 materials-card-v2 d-block text-decoration-none text-reset detail-related-card">
                        <div class="materials-card-media">
                            <img src="@imageSequence[0]" data-image-sequence="@string.Join("|", imageSequence)"
                                 data-default-image="@imageSequence[0]" alt="@(product.Name ?? "Sản phẩm phế liệu")"
                                 class="img-fluid w-100 materials-hover-image" loading="lazy">
                            <span class="materials-badge">
                                <i class="bi bi-@(GetCategoryIcon(product.Category?.Name))"></i>
                                @(product.Category?.Name ?? "Phế liệu")
                            </span>
                        </div>
                        <div class="materials-card-body">
                            <h4 class="card-title">@(product.Name ?? "Sản phẩm đang cập nhật")</h4>
                            <p>@(product.ShortDescription ?? product.Description ?? "Đang cập nhật thông tin sản phẩm.")</p>
                            <span class="readmore">Xem chi tiết <i class="bi bi-arrow-right"></i></span>
                        </div>
                    </a>
                </div>
            }
        </div>
        <div class="materials-products-pagination swiper-pagination detail-related-pagination"></div>
    </div>
}
else
{
    <div class="col-12 text-center py-4">
        <p class="text-muted mb-0">Đang cập nhật danh sách sản phẩm...</p>
    </div>
}
