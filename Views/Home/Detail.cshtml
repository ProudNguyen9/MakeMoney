@model WebThuMuaPheLieu.ViewModels.ProductDetailViewModel
@{
  Layout = "_HomeLayout";
}

@{
  ViewData["Title"] = Model.Product.Name;

  string NormalizeAssetUrl(string? url)
  {
    if (string.IsNullOrWhiteSpace(url))
    {
      return "/images/no-image.png";
    }

    var normalized = url.Replace("\\", "/").Trim();

    if (normalized.StartsWith("~/"))
    {
      return $"/{normalized[2..]}";
    }

    if (normalized.StartsWith("http://") || normalized.StartsWith("https://") || normalized.StartsWith("/"))
    {
      return normalized;
    }

    return "/" + normalized.TrimStart('/');
  }

  var galleryImages = Model.Images?.OrderBy(x => x.OrderIndex).ToList() ?? new List<ProductImage>();

  var coverImage = !string.IsNullOrWhiteSpace(Model.Product.PrimaryImage)
      ? NormalizeAssetUrl(Model.Product.PrimaryImage)
      : (galleryImages.Any() ? NormalizeAssetUrl(galleryImages.First().ImageUrl) : "/images/no-image.png");

  var primaryImage = coverImage;
  var primaryAlt = Model.Product.Name;
  var heroTitle = Model.Product.Name;
  var heroDescription = !string.IsNullOrWhiteSpace(Model.Product.Description)
  ? Model.Product.Description
  : !string.IsNullOrWhiteSpace(Model.Product.ShortDescription)
      ? Model.Product.ShortDescription
      : "Thông tin sản phẩm đang được cập nhật.";
  var shortDescription = !string.IsNullOrWhiteSpace(Model.Product.ShortDescription)
      ? Model.Product.ShortDescription
      : !string.IsNullOrWhiteSpace(Model.Product.Description)
          ? Model.Product.Description
          : "Thông tin đang được cập nhật.";
  var formattedPrice = !string.IsNullOrWhiteSpace(Model.Product.PriceLabel)
      ? Model.Product.PriceLabel
      : (Model.Product.PriceValue.HasValue
          ? $"{Model.Product.PriceValue.Value:N0} đ/{Model.Product.Unit}"
          : "Liên hệ");

  var priceLabel = "Giá thu mua";
  var priceNote = "Giá có thể thay đổi theo chất lượng và số lượng";

  var trendIcon = "info";
  var trendText = "Giá mớí nhất ";

  var histories = Model.PriceHistories?
      .Where(x => x.PriceValue.HasValue)
      .OrderByDescending(x => x.EffectiveDate)
      .ToList() ?? new List<PriceHistory>();

  if (histories.Count >= 2)
  {
    var latestPrice = histories[0].PriceValue ?? 0;
    var previousPrice = histories[1].PriceValue ?? 0;

    if (previousPrice > 0)
    {
      var percentChange = ((latestPrice - previousPrice) / previousPrice) * 100;

      if (percentChange > 0)
      {
        trendIcon = "trending_up";
        trendText = $"Tăng {Math.Abs(percentChange):0.#}% so với kỳ trước";
      }
      else if (percentChange < 0)
      {
        trendIcon = "trending_down";
        trendText = $"Giảm {Math.Abs(percentChange):0.#}% so với kỳ trước";
      }
      else
      {
        trendIcon = "trending_flat";
        trendText = "Giá giữ ổn định so với kỳ trước";
      }
    }
    else
    {
      trendIcon = "info";
      trendText = "Giá vừa được cập nhật";
    }
  }
  else if (histories.Count == 1)
  {
    trendIcon = "schedule";
    trendText = "Giá mới nhất đã được cập nhật";
  }
}
@section Styles {
  <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800;900&display=swap"
        rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
  <link href="~/css/detail.css" rel="stylesheet" />
}
@section Scripts {
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    (() => {
    const mainImage = document.getElementById('hero-main-image');
    const mainTitle = document.getElementById('hero-main-title');
    const mainDesc = document.getElementById('hero-main-desc');
    const mainKicker = document.getElementById('hero-main-kicker');
    const thumbs = document.querySelectorAll('.hero-thumb');

    if (mainImage && mainTitle && mainDesc && mainKicker && thumbs.length) {
    const setActiveThumb = (activeThumb) => {
    thumbs.forEach((thumb) => thumb.classList.remove('active'));
    activeThumb.classList.add('active');
    };

    thumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => {
    const image = thumb.dataset.image;
    const alt = thumb.dataset.alt;
    const title = thumb.dataset.title;
    const desc = thumb.dataset.desc;
    const kicker = thumb.dataset.kicker;

    if (image) mainImage.src = image;
    if (alt) mainImage.alt = alt;
    if (title) mainTitle.textContent = title;
    if (desc) mainDesc.textContent = desc;
    if (kicker) mainKicker.textContent = kicker;

    setActiveThumb(thumb);
    });
    });
    }

    const relatedProductsSwiperElement = document.querySelector('.detail-related-products-swiper');
    const prevBtn = document.querySelector('.materials-prev');
    const nextBtn = document.querySelector('.materials-next');
 
    if (relatedProductsSwiperElement && typeof Swiper !== 'undefined') {
    const totalSlides = relatedProductsSwiperElement.querySelectorAll('.swiper-slide').length;
    const shouldLoop = totalSlides > 4;
 
    new Swiper(relatedProductsSwiperElement, {
    speed: 900,
    loop: shouldLoop,
    slidesPerView: 1.15,
    spaceBetween: 16,
    grabCursor: true,
    autoplay: {
    delay: 2800,
    disableOnInteraction: false,
    pauseOnMouseEnter: true
    },
    navigation: prevBtn && nextBtn ? {
    prevEl: prevBtn,
    nextEl: nextBtn
    } : undefined,
    pagination: {
    el: '.detail-related-pagination',
    clickable: true
    },
    breakpoints: {
    576: {
    slidesPerView: 1.35,
    spaceBetween: 16
    },
    768: {
    slidesPerView: 2,
    spaceBetween: 18
    },
    992: {
    slidesPerView: 3,
    spaceBetween: 20
    },
    1200: {
    slidesPerView: 4,
    spaceBetween: 20
    }
    }
    });
 
    relatedProductsSwiperElement.querySelectorAll('.materials-hover-image').forEach((imageElement) => {
    const sequence = (imageElement.dataset.imageSequence || '')
    .split('|')
    .map((item) => item.trim())
    .filter((item) => item.length > 0);
 
    if (sequence.length <= 1) {
    return;
    }
 
    const defaultImage = imageElement.dataset.defaultImage || sequence[0];
    let currentIndex = 0;
    let intervalId = null;
 
    const startHoverRotation = function () {
    if (intervalId) {
    return;
    }
 
    intervalId = window.setInterval(() => {
    currentIndex = (currentIndex + 1) % sequence.length;
    imageElement.src = sequence[currentIndex];
    }, 900);
    };
 
    const stopHoverRotation = function () {
    if (intervalId) {
    window.clearInterval(intervalId);
    intervalId = null;
    }
 
    currentIndex = 0;
    imageElement.src = defaultImage;
    };
 
    imageElement.addEventListener('mouseenter', startHoverRotation);
    imageElement.addEventListener('mouseleave', stopHoverRotation);
    });
    }
    })();
  </script>
}


