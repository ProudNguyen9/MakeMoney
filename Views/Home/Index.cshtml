                                                                    <img src="@imageSequence[0]"
                                                                         data-image-sequence="@string.Join("|", imageSequence)"
                                                                         data-default-image="@imageSequence[0]"
                                                                         alt="@product.Name"
                                                                         class="img-fluid w-100 materials-hover-image"
                                                                         loading="lazy">
                                                                    <span class="materials-badge">
                                                                        <i class="bi bi-@(GetCategoryIcon(product.Category?.Name))"></i>
                                                                        @(product.Category?.Name ?? "Phế liệu")
                                                                    </span>
                                                                </div>
