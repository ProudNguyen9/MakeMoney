                                            <div class="materials-grid-swiper swiper" data-aos="fade-up" data-aos-delay="100">
                                                <div class="swiper-wrapper">
                                                    @foreach (var product in productList)
                                                    {
                                                        var imageSequence = BuildImageSequence(product);

                                                        <div class="swiper-slide">
