                                        <script>
                                            document.addEventListener('DOMContentLoaded', function () {
                                                const materialsSwiperElement = document.querySelector('.materials-grid-swiper');

                                                if (materialsSwiperElement && typeof Swiper !== 'undefined') {
                                                    const totalSlides = materialsSwiperElement.querySelectorAll('.swiper-slide').length;
                                                    const shouldLoop = totalSlides > 8;

                                                    new Swiper(materialsSwiperElement, {
                                                        speed: 800,
                                                        loop: false,
                                                        rewind: true,
                                                        slidesPerView: 1,
                                                        slidesPerGroup: 1,
                                                        spaceBetween: 16,
                                                        grabCursor: true,
                                                        allowTouchMove: true,
                                                        simulateTouch: true,
                                                        touchStartPreventDefault: false,
                                                        watchOverflow: true,
                                                        grid: {
                                                            rows: 2,
                                                            fill: 'row'
                                                        },
                                                        autoplay: {
                                                            delay: 5000,
                                                            disableOnInteraction: false,
                                                            pauseOnMouseEnter: false,
                                                            stopOnLastSlide: false
                                                        },
                                                        pagination: {
                                                            el: '.materials-products-pagination',
                                                            clickable: true
                                                        },
                                                        breakpoints: {
                                                            576: {
                                                                slidesPerView: 2,
                                                                spaceBetween: 18,
                                                                grid: {
                                                                    rows: 2,
                                                                    fill: 'row'
                                                                }
                                                            },
                                                            992: {
                                                                slidesPerView: 3,
                                                                spaceBetween: 20,
                                                                grid: {
                                                                    rows: 2,
                                                                    fill: 'row'
                                                                }
                                                            },
                                                            1200: {
                                                                slidesPerView: 4,
                                                                spaceBetween: 20,
                                                             
                                                                grid: {
                                                                    rows: 2,
                                                                    fill: 'row'
                                                                }
                                                            }
                                                        }
                                                    });
                                                }

                                                document.querySelectorAll('.materials-hover-image').forEach(function (imageElement) {
                                                    const sequence = (imageElement.dataset.imageSequence || '')
                                                        .split('|')
                                                        .filter(Boolean);

                                                    if (sequence.length <= 1) {
                                                        return;
                                                    }

                                                    const defaultImage = imageElement.dataset.defaultImage || sequence[0];
                                                    let intervalId = null;
                                                    let currentIndex = 0;

                                                    const startHoverRotation = function () {
                                                        if (intervalId) {
                                                            return;
                                                        }

                                                        currentIndex = sequence.length > 1 ? 1 : 0;
                                                        imageElement.src = sequence[currentIndex];

                                                        intervalId = setInterval(function () {
                                                            currentIndex = (currentIndex + 1) % sequence.length;
                                                            imageElement.src = sequence[currentIndex];
                                                        }, 900);
                                                    };

                                                    const stopHoverRotation = function () {
                                                        if (intervalId) {
                                                            clearInterval(intervalId);
                                                            intervalId = null;
                                                        }

                                                        currentIndex = 0;
                                                        imageElement.src = defaultImage;
                                                    };

                                                    imageElement.addEventListener('mouseenter', startHoverRotation);
                                                    imageElement.addEventListener('mouseleave', stopHoverRotation);
                                                });
                                            });
                                        </script>

                                        @functions {
                                            string GetCategoryIcon(string? categoryName)
                                            {
                                                if (string.IsNullOrWhiteSpace(categoryName)) return "box-seam";

                                                return categoryName.ToLower() switch
                                                {
                                                    var c when c.Contains("sắt") || c.Contains("thép") || c.Contains("kim loại") => "building",
                                                    var c when c.Contains("đồng") || c.Contains("nhôm") || c.Contains("inox") => "gem",
                                                    var c when c.Contains("giấy") || c.Contains("carton") => "box-seam",
                                                    var c when c.Contains("máy") || c.Contains("điện") || c.Contains("cáp") => "cpu",
                                                    var c when c.Contains("xưởng") || c.Contains("công nghiệp") => "gear-wide-connected",
                                                    var c when c.Contains("dân dụng") || c.Contains("gia đình") => "house-door-fill",
                                                    var c when c.Contains("nhựa") => "recycle",
                                                    _ => "box-seam"
                                                };
                                            }

                                            string NormalizeImagePath(string? imagePath)
                                            {
                                                if (string.IsNullOrWhiteSpace(imagePath))
                                                {
                                                    return "/assets/images/products/satdac1.jpg";
                                                }

                                                var normalized = imagePath.Replace("\\", "/").Trim();

                                                if (normalized.StartsWith("~/"))
                                                {
                                                    return $"/{normalized[2..]}";
                                                }

                                                if (!normalized.StartsWith('/'))
                                                {
                                                    normalized = $"/{normalized}";
                                                }

                                                return normalized;
                                            }

                                            string[] BuildImageSequence(WebThuMuaPheLieu.Models.Product product)
                                            {
                                                var imageSequence = (product.ProductImages ?? new List<WebThuMuaPheLieu.Models.ProductImage>())
                                                    .OrderBy(image => image.OrderIndex ?? int.MaxValue)
                                                    .Select(image => NormalizeImagePath(image.ImageUrl))
                                                    .Where(path => !string.IsNullOrWhiteSpace(path))
                                                    .Distinct()
                                                    .ToList();

                                                var primaryImage = NormalizeImagePath(product.PrimaryImage);

                                                if (!imageSequence.Any())
                                                {
                                                    imageSequence.Add(primaryImage);
                                                }
                                                else if (!imageSequence.Any(path => string.Equals(path, primaryImage, StringComparison.OrdinalIgnoreCase)))
                                                {
                                                    imageSequence.Insert(0, primaryImage);
                                                }

                                                return imageSequence.ToArray();
                                            }

                                        }

