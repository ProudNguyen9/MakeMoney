@model WebThuMuaPheLieu.Models.ProductIndexViewModel

@{
    Layout = "_HomeLayout";
    ViewData["Title"] = "Mặt hàng";
}

< <section id="materials" class="services home-card-section">
    <div class="container-fluid home-section-shell" data-aos="fade-up">
        <div class="section-header mb-0">
            <h2>Thu mua tất cả các loại phế liệu</h2>
            <p class="text-dart">
                Danh mục thu mua được trình bày rõ ràng để khách hàng dễ hình dung ngay từ đầu: chúng tôi tiếp nhận
                nhiều loại phế liệu từ dân dụng, văn phòng, cửa hàng nhỏ lẻ cho đến hàng công nghiệp số lượng lớn
                tại kho xưởng, công trình và doanh nghiệp, đồng thời hỗ trợ khảo sát tận nơi, tư vấn phân loại,
                báo giá minh bạch và thu gom nhanh gọn trong suốt quá trình thanh lý.
            </p>
        </div>

        <style>
                    #materials .materials-grid-swiper {
                        overflow: hidden;
                        padding: 4px 2px 34px;
                    }

                    #materials .materials-grid-swiper .swiper-wrapper {
                        align-items: stretch;
                    }

                    #materials .materials-grid-swiper .swiper-slide {
                        height: auto;
                        display: flex;
                    }

                    #materials .materials-grid-swiper .materials-card-v2 {
                        width: 100%;
                        height: 100%;
                    }

                    #materials .materials-grid-swiper .materials-card-media {
                        aspect-ratio: 16 / 10;
                        height: auto;
                        min-height: 220px;
                    }

                    #materials .materials-products-pagination {
                        bottom: 0 !important;
                    }

                    #materials .materials-products-pagination .swiper-pagination-bullet {
                        width: 10px;
                        height: 10px;
                        background: rgba(15, 23, 42, 0.22);
                        opacity: 1;
                    }

                    #materials .materials-products-pagination .swiper-pagination-bullet-active {
                        background: #198754;
                    }

                    #materials .materials-card-body .readmore {
                        display: inline-flex;
                        align-items: center;
                        gap: 8px;
                        color: rgba(15, 23, 42, 0.62);
                        opacity: 0.72;
                        transition: color 0.3s ease, opacity 0.3s ease, gap 0.3s ease, text-shadow 0.3s ease;
                    }

                    #materials .materials-card-body .readmore i {
                        font-size: 15px;
                    }

                    #materials .materials-card-v2:hover .readmore {
                        color: #198754;
                        opacity: 1;
                        gap: 12px;
                        text-shadow: 0 0 18px rgba(25, 135, 84, 0.22);
                    }
        </style>

        <div id="product-list" class="home-cards-grid">
            @foreach (var product in Model.Products)
            {
                <div data-aos="fade-up" data-aos-delay="100">
                    <a asp-controller="Home" asp-action="Detail" asp-route-slug="@product.Slug" asp-route-id="@product.Id"
                           class="card-item h-100 materials-card-v2 d-block text-decoration-none text-reset">
                        <div class="materials-card-media">
                            <img src="@product.PrimaryImage" data-image-sequence="@string.Join("|", product.Images)"
                                 data-default-image="@product.PrimaryImage" alt="@product.Name"
                                 class="img-fluid w-100 materials-hover-image" loading="lazy">
                            <span class="materials-badge">
                                <i class="bi bi-@product.CategoryIcon"></i>
                                @(product.CategoryName ?? "Phế liệu")
                            </span>
                        </div>
                        <div class="materials-card-body">
                            <h4 class="card-title">@product.Name</h4>
                            <p>@(product.ShortDescription ?? product.Description ?? "Đang cập nhật thông tin sản phẩm.")</p>
                            <span class="readmore">Xem chi tiết <i class="bi bi-arrow-right"></i></span>
                        </div>
                    </a>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="product-pagination mt-5">
                <ul id="product-pagination" class="pagination justify-content-center">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : string.Empty)">
                        <a class="page-link js-page-link"
                           href='@Url.Action("Index", "Product", new { page = Model.CurrentPage - 1 })'
                           data-page="@(Model.CurrentPage - 1)">Trước</a>
                    </li>

                    @for (var pageNumber = 1; pageNumber <= Model.TotalPages; pageNumber++)
                    {
                        <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : string.Empty)">
                            <a class="page-link js-page-link" href='@Url.Action("Index", "Product", new { page = pageNumber })'
                               data-page="@pageNumber">@pageNumber</a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : string.Empty)">
                        <a class="page-link js-page-link"
                           href='@Url.Action("Index", "Product", new { page = Model.CurrentPage + 1 })'
                           data-page="@(Model.CurrentPage + 1)">Sau</a>
                    </li>
                </ul>
            </nav>
        }

    </div>
</section>

<script>
        (() => {
            const productList = document.getElementById('product-list');
            const pagination = document.getElementById('product-pagination');

            function renderProducts(products) {
                if (!productList) return;

                productList.innerHTML = products.map((product, index) => {
                    const imageSequence = (product.images ?? []).filter(Boolean);
                    const primaryImage = product.primaryImage ?? imageSequence[0] ?? '/assets/images/no-image.png';
                    const detailUrl = `/Home/Detail/${product.slug ?? ''}/${product.id}`;

                    return `
                    <div data-aos="fade-up" data-aos-delay="${100 + (index * 50)}">
                        <a href="${detailUrl}" class="card-item h-100 materials-card-v2 d-block text-decoration-none text-reset">
                            <div class="materials-card-media">
                                <img src="${primaryImage}"
                                     data-image-sequence="${imageSequence.join('|')}"
                                     data-default-image="${primaryImage}"
                                     alt="${product.name}"
                                     class="img-fluid w-100 materials-hover-image"
                                     loading="lazy">
                                <span class="materials-badge">
                                    <i class="bi bi-${product.categoryIcon ?? 'box-seam'}"></i>
                                    ${product.categoryName ?? 'Phế liệu'}
                                </span>
                            </div>
                            <div class="materials-card-body">
                                <h4 class="card-title">${product.name}</h4>
                                <p>${product.shortDescription ?? product.description ?? 'Đang cập nhật thông tin sản phẩm.'}</p>
                                <span class="readmore">Xem chi tiết <i class="bi bi-arrow-right"></i></span>
                            </div>
                        </a>
                    </div>`;
                }).join('');

                bindProductHoverRotation();
            }

            function renderPagination(currentPage, totalPages) {
                if (!pagination) return;

                let html = `
                <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                    <a class="page-link js-page-link" href="/Product?page=${currentPage - 1}" data-page="${currentPage - 1}">Trước</a>
                </li>`;

                for (let pageNumber = 1; pageNumber <= totalPages; pageNumber++) {
                    html += `
                    <li class="page-item ${pageNumber === currentPage ? 'active' : ''}">
                        <a class="page-link js-page-link" href="/Product?page=${pageNumber}" data-page="${pageNumber}">${pageNumber}</a>
                    </li>`;
                }

                html += `
                <li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                    <a class="page-link js-page-link" href="/Product?page=${currentPage + 1}" data-page="${currentPage + 1}">Sau</a>
                </li>`;

                pagination.innerHTML = html;
                bindPaginationAjax();
            }

            async function loadPage(page) {
                if (!pagination || page < 1) return;

                const response = await fetch(`/Product/GetPagedProducts?page=${page}`, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (!response.ok) {
                    return;
                }

                const data = await response.json();
                renderProducts(data.products);
                renderPagination(data.currentPage, data.totalPages);
                window.history.pushState({}, '', `/Product?page=${data.currentPage}`);
            }

            function bindPaginationAjax() {
                document.querySelectorAll('.js-page-link').forEach(link => {
                    link.addEventListener('click', event => {
                        const page = Number(link.dataset.page);
                        const pageItem = link.closest('.page-item');

                        if (pageItem?.classList.contains('disabled') || pageItem?.classList.contains('active')) {
                            event.preventDefault();
                            return;
                        }

                        event.preventDefault();
                        loadPage(page);
                    });
                });
            }

            function bindProductHoverRotation() {
                document.querySelectorAll('.materials-hover-image').forEach(function (imageElement) {
                    const sequence = (imageElement.dataset.imageSequence || '')
                        .split('|')
                        .filter(Boolean);

                    if (sequence.length <= 1) {
                        return;
                    }

                    const defaultImage = imageElement.dataset.defaultImage || sequence[0];
                    let intervalId = null;
                    let currentIndex = 0;

                    const startHoverRotation = function () {
                        if (intervalId) {
                            return;
                        }

                        currentIndex = sequence.length > 1 ? 1 : 0;
                        imageElement.src = sequence[currentIndex];

                        intervalId = setInterval(function () {
                            currentIndex = (currentIndex + 1) % sequence.length;
                            imageElement.src = sequence[currentIndex];
                        }, 900);
                    };

                    const stopHoverRotation = function () {
                        if (intervalId) {
                            clearInterval(intervalId);
                            intervalId = null;
                        }

                        currentIndex = 0;
                        imageElement.src = defaultImage;
                    };

                    imageElement.addEventListener('mouseenter', startHoverRotation);
                    imageElement.addEventListener('mouseleave', stopHoverRotation);
                });
            }

            bindPaginationAjax();
            bindProductHoverRotation();

            window.addEventListener('popstate', () => {
                const params = new URLSearchParams(window.location.search);
                const page = Number(params.get('page') ?? '1');
                loadPage(page);
            });
        })();
</script>

@await Component.InvokeAsync("RecentNewsSectionComponent")

